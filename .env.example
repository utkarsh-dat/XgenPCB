# ============================================
# XgenPCB - Environment Configuration
# Production-Ready Template
# ============================================

# ── Database ───────────────────────────────────────────────
POSTGRES_DB=xgenpcb
POSTGRES_USER=xgenpcb
POSTGRES_PASSWORD=change_me_secure
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Or use SQLite: DATABASE_URL=sqlite:///./data/pcbbuilder.db

# ── Redis ───────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── MinIO (S3 Storage) ───────────────────────────────────────
MINIO_USER=minioadmin
MINIO_PASSWORD=change_me
S3_BUCKET=xgenpcb-assets

# ── AI / LLM ─────────────────────────────────────────────────
USE_OLLAMA=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini

# ── Auth ────────────────────────────────────────────────────
JWT_SECRET=change_this_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ── Application ──────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
APP_PORT=8000
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:5174